rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      // Note: for high security we rely on 'users' collection with role == 'admin'
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // USERS
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid &&
                    isValidUser(incoming()) && incoming().role == 'user' && 
                    incoming().createdAt >= request.time.toMillis() - 60000 && incoming().createdAt <= request.time.toMillis() + 60000 && 
                    incoming().updatedAt >= request.time.toMillis() - 60000 && incoming().updatedAt <= request.time.toMillis() + 60000;
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'updatedAt']) && 
         incoming().name is string && incoming().name.size() <= 100 &&
         incoming().updatedAt >= request.time.toMillis() - 60000 && incoming().updatedAt <= request.time.toMillis() + 60000)
      ) || isAdmin();
    }

    // PROVIDERS
    function isValidProvider(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'status', 'kycVerified', 'rating', 'reviewsCount', 'createdAt', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.status in ['pending', 'active', 'rejected', 'blocked'] &&
             data.kycVerified is bool &&
             data.rating is number && data.reviewsCount is number &&
             data.createdAt is number && data.updatedAt is number;
    }
    match /providers/{providerId} {
      allow get: if true; 
      allow list: if true; 
      allow create: if isSignedIn() && isValidId(providerId) && providerId == request.auth.uid &&
                    isValidProvider(incoming()) && incoming().status == 'pending' &&
                    incoming().kycVerified == false && incoming().rating == 0 && incoming().reviewsCount == 0 &&
                    incoming().createdAt >= request.time.toMillis() - 60000 && incoming().createdAt <= request.time.toMillis() + 60000 && 
                    incoming().updatedAt >= request.time.toMillis() - 60000 && incoming().updatedAt <= request.time.toMillis() + 60000;
      allow update: if isSignedIn() && isValidId(providerId) && (
        (providerId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'services', 'updatedAt']) &&
         incoming().updatedAt >= request.time.toMillis() - 60000 && incoming().updatedAt <= request.time.toMillis() + 60000) ||
        isAdmin()
      );
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // SERVICES
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // BOOKINGS
    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'providerId', 'serviceId', 'categoryId', 'status', 'scheduledAt', 'amount', 'paymentStatus', 'address', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.providerId is string && data.providerId.size() <= 128 &&
             data.serviceId is string && data.serviceId.size() <= 128 &&
             data.categoryId is string && data.categoryId.size() <= 128 &&
             data.status in ['pending', 'accepted', 'in_progress', 'completed', 'cancelled'] &&
             data.scheduledAt is number &&
             data.amount is number &&
             data.paymentStatus in ['pending', 'paid', 'refunded'] &&
             data.address is string && data.address.size() <= 500 &&
             data.createdAt is number && data.updatedAt is number;
    }
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || existing().providerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.providerId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidId(bookingId) && 
                    isValidBooking(incoming()) && 
                    incoming().status == 'pending' && 
                    incoming().paymentStatus == 'pending' &&
                    incoming().createdAt >= request.time.toMillis() - 60000 && incoming().createdAt <= request.time.toMillis() + 60000 && 
                    incoming().updatedAt >= request.time.toMillis() - 60000 && incoming().updatedAt <= request.time.toMillis() + 60000 &&
                    exists(/databases/$(database)/documents/providers/$(incoming().providerId));
      
      allow update: if isSignedIn() && isValidId(bookingId) && (
        (existing().userId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         existing().status in ['pending', 'accepted'] &&
         incoming().status == 'cancelled' &&
         incoming().updatedAt >= request.time.toMillis() - 60000 && incoming().updatedAt <= request.time.toMillis() + 60000) ||
        (existing().providerId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         (
           (existing().status == 'pending' && incoming().status in ['accepted', 'cancelled']) ||
           (existing().status == 'accepted' && incoming().status == 'in_progress') ||
           (existing().status == 'in_progress' && incoming().status == 'completed')
         ) &&
         incoming().updatedAt >= request.time.toMillis() - 60000 && incoming().updatedAt <= request.time.toMillis() + 60000) ||
        isAdmin()
      );
    }

    // REVIEWS
    function isValidReview(data) {
      return data.keys().hasAll(['bookingId', 'userId', 'providerId', 'rating', 'comment', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.bookingId is string && data.bookingId.size() <= 128 &&
             data.providerId is string && data.providerId.size() <= 128 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.createdAt is number;
    }
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(reviewId) &&
                    isValidReview(incoming()) &&
                    incoming().createdAt >= request.time.toMillis() - 60000 && incoming().createdAt <= request.time.toMillis() + 60000 &&
                    exists(/databases/$(database)/documents/bookings/$(incoming().bookingId)) &&
                    get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.userId == request.auth.uid &&
                    get(/databases/$(database)/documents/bookings/$(incoming().bookingId)).data.status == 'completed';
      allow update, delete: if isAdmin();
    }
  }
}
